# OpenForge API credentials (SAFE TO COMMIT — template only, no real secrets)
#
# Setup:
#   1. Copy this file to secrets.toml (same directory):
#        cp secrets.toml.example secrets.toml
#   2. Open secrets.toml and replace every PASTE_... placeholder below.
#   3. Never commit secrets.toml (it is listed in .gitignore).
#
# DigiKey: https://developer.digikey.com/ → Apps → your app → Client ID / Secret

[digikey]
client_id = "PASTE_YOUR_DIGIKEY_CLIENT_ID_HERE"
client_secret = "PASTE_YOUR_DIGIKEY_CLIENT_SECRET_HERE"

# Optional — KB population Phase 2 (Nexar PDF URL resolution)
# Nexar: https://portal.nexar.com/ → API → token
[nexar]
api_token = "PASTE_YOUR_NEXAR_API_TOKEN_HERE"
