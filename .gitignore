# Local-only development guides (not published to GitHub)
documents/guides/

# Python / tooling
venv/
.venv/
__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ML artifacts (both main + prototype)
models/
/output/
logs/
data/raw/*
!data/raw/.gitkeep
data/graph/*
!data/graph/.gitkeep
*.pt
*.pth

# OS / IDE
.DS_Store
.env

# Local API credentials (DigiKey, Nexar, etc.) — use secrets.toml.example as template
secrets.toml

# KG snapshots (scripts/kg_snapshot.py): the .dump/.graphml data files can be
# large binaries and shouldn't bloat the repo, but SNAPSHOT_LOG.md is small,
# text, and valuable history on its own even without the underlying files —
# so it stays tracked while everything else in the folder is ignored.
kg_snapshots/*.dump
kg_snapshots/*.graphml
